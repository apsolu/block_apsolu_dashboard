{{!
    @template block_apsolu_dashboard/courses

    Template Moodle pour afficher la liste des cours.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * wwwroot
    * count_courses
    * courses
        * id
        * fullname
        * viewable
        * count_enrolments
        * enrolments

    Example context (json):
    {
        "wwwroot": "https://apsolu.fr",
        "count_courses": 0,
        "courses": []
    }
}}
<div id="courses" class="tab-pane fade in">
  {{! Liste des cours de l'utilisateur. }}
  {{^count_courses}}
  <p class="alert alert-info">{{#str}}no_courses, block_apsolu_dashboard{{/str}}</p>
  {{/count_courses}}

  {{#count_courses}}
  <ul class="list-unstyled">
    {{#courses}}
    <li class="well mb-1">
      {{^viewable}}
      <p>{{fullname}}</p>
      {{/viewable}}

      {{#viewable}}
      <p><a href="{{wwwroot}}/course/view.php?id={{id}}">{{fullname}}</a></p>
      {{/viewable}}

      {{#count_enrolments}}
      <ul>
        {{#enrolments}}
        <li>{{.}}</li>
        {{/enrolments}}
      </ul>
      {{/count_enrolments}}
    </li>
    {{/courses}}
  </ul>
  {{/count_courses}}
</div>
